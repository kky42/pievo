{
  "name": "pievo",
  "version": "1.0.0",
  "private": true,
  "description": "Pievo — multi-user scheduled-loop manager. Server schedules/stores/auths; execution is BYOA on the user's own machine (Claude Code or Codex).",
  "type": "module",
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @kky42/pievo-server dev",
    "build": "pnpm --filter @kky42/pievo-server build",
    "start": "pnpm --filter @kky42/pievo-server start",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @kky42/pievo-server test && pnpm --filter @kky42/pievo test"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
